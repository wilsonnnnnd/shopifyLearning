<div class="wm-product-benefits">
  <h2 class="wm-benefits-title">{{ section.settings.title }}</h2>

  <ul class="wm-benefits-list" role="list">
    {% if section.settings.benefit1 != blank %}
      <li class="wm-benefit-item">
        <span class="wm-benefit-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="wm-benefit-text">{{ section.settings.benefit1 }}</span>
      </li>
    {% endif %}

    {% if section.settings.benefit2 != blank %}
      <li class="wm-benefit-item">
        <span class="wm-benefit-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3 12h3l3-6 6 12h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="wm-benefit-text">{{ section.settings.benefit2 }}</span>
      </li>
    {% endif %}

    {% if section.settings.benefit3 != blank %}
      <li class="wm-benefit-item">
        <span class="wm-benefit-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12 2v6M12 22v-6M4.9 4.9l4.2 4.2M19.1 19.1l-4.2-4.2M2 12h6M22 12h-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="wm-benefit-text">{{ section.settings.benefit3 }}</span>
      </li>
    {% endif %}
  </ul>
</div>

{% schema %}
{
  "name": "Product Benefits",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Why choose this product"
    },
    {
      "type": "text",
      "id": "benefit1",
      "label": "Benefit 1",
      "default": "High quality materials"
    },
    {
      "type": "text",
      "id": "benefit2",
      "label": "Benefit 2",
      "default": "Fast shipping across Australia"
    },
    {
      "type": "text",
      "id": "benefit3",
      "label": "Benefit 3",
      "default": "30-day easy returns"
    }
  ],
  "presets": [
    {
      "name": "Product Benefits"
    }
  ]
}
{% endschema %}